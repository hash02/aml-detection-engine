# Copy this file to deploy/.env before bringing the compose stack up.
# Anything unset falls back to the demo/open defaults.

# Streamlit gate
AML_APP_PASSWORD=
AML_REVIEWER_USERNAMES=
AML_ADMIN_USERNAMES=
AML_SESSION_SECRET=

# FastAPI auth + rate limit
AML_API_TOKEN=
AML_API_RATE_LIMIT=100/minute

# Audit + case stores (paths inside the container; volume-mounted to host)
AML_AUDIT_DB=/app/data/audit.db
AML_CASES_DB=/app/data/cases.db

# Feeds
FEEDS_OFFLINE=
CHAINALYSIS_RPC_URL=

# External APIs (optional)
ETHERSCAN_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=

# Observability (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
APP_ENV=prod
APP_RELEASE=
PROMETHEUS_PORT=

LOG_LEVEL=INFO
