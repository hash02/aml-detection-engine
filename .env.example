# NEXUS-RISK AML Engine — environment variables
# Copy this file to `.env` (never commit .env). All values are optional;
# absent vars fall back to safe in-process defaults or feature-off.

# ── Auth (Streamlit gate) ────────────────────────────────────────────────
# When set, the Streamlit app requires this password on entry.
# Leave unset to run the public demo mode.
AML_APP_PASSWORD=

# Comma-separated list of allowed reviewer usernames. If empty, every
# authenticated user is treated as an analyst (read/query only).
AML_REVIEWER_USERNAMES=

# Session secret for signing the auth cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AML_SESSION_SECRET=

# ── Threat-intel feeds ───────────────────────────────────────────────────
# Set to 1 to skip every network call in feeds.py (CI / air-gapped)
FEEDS_OFFLINE=

# Optional: HTTPS URL of an Ethereum JSON-RPC endpoint for the
# Chainalysis Sanctions Oracle belt-and-braces check. Any mainnet RPC
# works (Infura / Alchemy / public node).
CHAINALYSIS_RPC_URL=

# ── External APIs ────────────────────────────────────────────────────────
# Optional Etherscan V2 API key (5 rps vs 1 rp/5s without). Register at
# https://etherscan.io/register — free, no card.
ETHERSCAN_API_KEY=

# Optional Telegram bot token + chat id for on-alert notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Observability ────────────────────────────────────────────────────────
# Sentry DSN — set to enable exception reporting. Unset = noop.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
APP_ENV=dev
APP_RELEASE=dev

# Port to expose Prometheus metrics on. Unset = disable the exporter.
PROMETHEUS_PORT=

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
